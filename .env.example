# 2GIS Catalog / Places API key
# Get one free at https://dev.2gis.com
DGIS_API_KEY=your_2gis_api_key_here

# Path to the OAuth 2.0 Desktop App credentials JSON you downloaded
# from Google Cloud Console → APIs & Services → Credentials
GOOGLE_OAUTH_JSON=oauth_credentials.json

YANDEX_API_KEY=your_yandex_key

# (Optional) Paste an existing Google Sheet ID here to reuse it.
# Leave blank to auto-create a new sheet on first run.
SHEET_ID=

# Tab name inside the Google Sheet
SHEET_NAME=Parking Almaty

# Max pages fetched per search query (10 results/page).
# Demo 2GIS keys support up to 5 pages. Production keys: set to 20+.
MAX_PAGES=5

# Requests per second sent to 2GIS (be polite to the API)
REQUESTS_PER_SECOND=2

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
