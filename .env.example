# 2GIS Catalog / Places API key
DGIS_API_KEY=your_2gis_api_key_here

# Path to Google Cloud service account JSON file
GOOGLE_SA_JSON=service_account.json

# (Optional) Existing Google Sheet ID to write into.
# Leave blank to auto-create a new sheet.
SHEET_ID=

# Tab name inside the Google Sheet
SHEET_NAME=Parking Almaty

# Maximum pages fetched per search query (10 results/page).
# Demo keys support up to 5 pages. Production keys can go higher.
MAX_PAGES=5

# Requests per second (stay polite to the API)
REQUESTS_PER_SECOND=2

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
